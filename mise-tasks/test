#!/usr/bin/env bash
#MISE description="Run soar backend plugin tests"
set -euo pipefail

BACKEND="soar"
# jq is a widely available tool in the soar registry — good for a smoke test
TEST_TOOL="jq"

# Link the local plugin for development testing
mise plugin link --force "${BACKEND}" .

# Clear cache to ensure fresh results
mise cache clear

echo "=== soar backend plugin tests ==="
echo

# 1. Verify soar is available
echo "Checking that soar is installed..."
if ! command -v soar &>/dev/null; then
    echo "ERROR: soar is not installed."
    echo "  Install via: mise use -g github:pkgforge/soar"
    echo "  Or via:      curl -fsSL \"https://raw.githubusercontent.com/pkgforge/soar/main/install.sh\" | sh"
    exit 1
fi
echo "✓ soar found at $(command -v soar)"
echo

# 2. List versions
echo "Testing version listing for ${TEST_TOOL}..."
if mise ls-remote "${BACKEND}:${TEST_TOOL}"; then
    echo "✓ Version listing works"
else
    echo "✗ Version listing failed"
    exit 1
fi
echo

# 3. Install
echo "Testing installation of ${TEST_TOOL}@latest..."
if mise install "${BACKEND}:${TEST_TOOL}@latest"; then
    echo "✓ Installation works"
else
    echo "✗ Installation failed"
    exit 1
fi
echo

# 4. Execute the installed tool
echo "Testing execution of ${TEST_TOOL}..."
if mise exec "${BACKEND}:${TEST_TOOL}@latest" -- "${TEST_TOOL}" --version; then
    echo "✓ Tool execution works"
else
    echo "✗ Tool execution failed"
    exit 1
fi
echo

echo "=== All tests passed ==="
